        { "type": "SIMULATES", "direction": "in", "node": "tool.simulation.thinning" },
        { "type": "OUTPUT_OF", "direction": "in", "node": "process.modeling.pipeline" }
      ]
    },
    {
      "id": "artifact.dataset.events",
      "type": "EpistemicArtifact",
