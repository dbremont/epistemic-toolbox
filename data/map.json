      "represents": ["domain.temporal.events"],
      "edges": [
        { "type": "INPUT_TO", "direction": "out", "node": "process.modeling.pipeline" },
        { "type": "CONSTRAINED_BY", "direction": "out", "node": "constraint.data.noise" },
        { "type": "OPERATES_ON", "direction": "in", "node": "tool.inference.mle" }
      ]
    },
    {
      "id": "tool.inference.mle",
      "type": "EpistemicTool",
      "subtype": "StatisticalInference",
      "description": "Maximum likelihood estimation procedure",
      "edges": [
        { "type": "OPERATES_ON", "direction": "out", "node": "artifact.dataset.events" },
        { "type": "PRODUCES", "direction": "out", "node": "artifact.model.hawkes" },
        { "type": "USES", "direction": "in", "node": "agent.scientist" }
      ]
    },
    {
      "id": "tool.simulation.thinning",
      "type": "EpistemicTool",
      "subtype": "SamplingAlgorithm",
      "description": "Ogata thinning algorithm for simulating point processes",
      "edges": [
        { "type": "SIMULATES", "direction": "out", "node": "artifact.model.hawkes" }
      ]
    },
    {
      "id": "agent.scientist",
      "type": "EpistemicAgent",
      "subtype": "Human",
      "description": "Human researcher performing modeling and inference",
      "edges": [
        { "type": "USES", "direction": "out", "node": "tool.inference.mle" },
        { "type": "USES", "direction": "out", "node": "process.modeling.pipeline" }
      ]
    },
    {
