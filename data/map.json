      "edges": [
        { "type": "OUTPUT_OF", "direction": "out", "node": "artifact.model.hawkes" },
        { "type": "INPUT_TO", "direction": "in", "node": "artifact.dataset.events" },
        { "type": "USES", "direction": "in", "node": "agent.scientist" }
      ]
    },
    {
      "id": "standard.statistical.significance",
      "type": "EpistemicStandard",
      "subtype": "StatisticalCriterion",
      "description": "Threshold-based evaluation of hypothesis plausibility",
      "edges": [
        { "type": "EVALUATED_BY", "direction": "in", "node": "artifact.model.hawkes" }
      ]
    },
    {
      "id": "representation.symbolic.equation",
      "type": "EpistemicRepresentation",
      "subtype": "Symbolic",
      "description": "Mathematical equation encoding relationships",
